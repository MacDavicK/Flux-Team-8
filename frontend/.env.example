# Sentry DSN for error monitoring — get it from your Sentry project settings.
VITE_SENTRY_DSN=https://<key>@o<org>.ingest.us.sentry.io/<project>
# Optional: used by @sentry/vite-plugin to upload source maps on production builds.
SENTRY_ORG=<org-slug>
SENTRY_PROJECT=<project-slug>
SENTRY_AUTH_TOKEN=<auth-token>

SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
APP_URL=http://localhost:3000
APP_ENV=development

VITE_API_URL=http://localhost:8000
VITE_USE_MOCK=true
VITE_API_TIMEOUT=10000
VITE_ENABLE_DEMO_MODE=true
VITE_ENABLE_VOICE=false
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-supabase-anon-key
APP_URL=http://localhost:5173
