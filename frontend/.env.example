# Sentry DSN for error monitoring — get it from your Sentry project settings.
VITE_SENTRY_DSN=https://<key>@o<org>.ingest.us.sentry.io/<project>
# Optional: used by @sentry/vite-plugin to upload source maps on production builds.
SENTRY_ORG=<org-slug>
SENTRY_PROJECT=<project-slug>
SENTRY_AUTH_TOKEN=<auth-token>

SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
APP_URL=http://localhost:3000
APP_ENV=development

# Backend API base URL — used by the Vite dev proxy to forward /api/* requests.
# Set to http://localhost:8000 when running the FastAPI backend locally.
# Leave empty (or unset) to rely solely on MSW mocks.
VITE_API_URL=http://localhost:8000

# Set to "true" to enable MSW mock handlers instead of hitting the real backend.
# Mocks are always disabled in PROD builds regardless of this flag.
VITE_ENABLE_MOCKS=false
